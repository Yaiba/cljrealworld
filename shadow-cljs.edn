;; shadow-cljs configuration
{:deps {:aliases [:cljs :cljs-dev]}
 ;; :dev-http {8080 {:root "resources/public"
 ;;                  :push-state/index "index.html"}}
 :builds
 {:app {:target :browser
        :devtools {:preloads [dev]
                   :repl-init-ns dev
                   :repl-pprint true}
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules {:main {:init-fn frontend.core/main}}}}}
